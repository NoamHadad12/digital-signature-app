{
  "framework": "vite",
  "devCommand": "vite --port 5175",
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "functions": {
    "api/analyze-pdf.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}