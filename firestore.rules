rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── documents collection ──────────────────────────────────────────────
    match /documents/{docId} {

      // Anyone who knows the document ID (i.e. received the signing link) can
      // fetch it. This is intentional \u2014 the opaque UUID acts as an access token.
      // Additionally, we check that the document has not expired (IDOR mitigation).
      allow get: if !('expiresAt' in resource.data) 
                    || request.time.toMillis() < resource.data.expiresAt;

      // Only authenticated users may list/query documents, and only their own
      // (clientId must equal the caller's uid). Enforced server-side via Firestore
      // rules so no client-side bypass is possible.
      allow list: if request.auth != null
                  && request.auth.uid == resource.data.clientId;

      // Authenticated users may create a document only if they set clientId to
      // their own uid. Prevents one user from creating documents on behalf of another.
      allow create: if request.auth != null
                    && request.resource.data.clientId == request.auth.uid;

      // Two categories of update are allowed:
      //   1. The document owner (clientId == uid) can update any field.
      //   2. An unauthenticated signer can update ONLY the status lifecycle fields
      //      (status, signedPdfUrl, signedAt). No other field may be touched.
      allow update: if
        (request.auth != null && resource.data.clientId == request.auth.uid)
        ||
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'signedPdfUrl', 'signedAt']);

      // Only the document owner may permanently delete a document.
      allow delete: if request.auth != null
                    && resource.data.clientId == request.auth.uid;

      // ── markers sub-collection ──────────────────────────────────────────
      match /markers/{markerId} {
        // Signers (unauthenticated) need to read markers to render the signing form.
        allow read: if true;

        // Only the document owner may write/modify marker positions.
        allow write: if request.auth != null
                     && get(/databases/$(database)/documents/documents/$(docId)).data.clientId
                        == request.auth.uid;
      }
    }

    // ── users collection ─────────────────────────────────────────────────
    // Stores firstName, lastName, and email for each registered user.
    // Only the owner may read or write their own profile document.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── logs collection ───────────────────────────────────────────────────
    // Append-only audit trail. Any client may write a log entry (signers are
    // unauthenticated), but only authenticated users may read the audit log.
    // To mitigate DoS, we enforce a strict schema and size limit.
    match /logs/{logId} {
      allow create: if request.resource.data.keys().hasAll(['actionType', 'timestamp', 'documentId'])
                    && request.resource.size < 2000;
      allow read:   if request.auth != null;
    }
  }
}
