rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function ownsDocument(documentId) {
      return request.auth != null
             && firestore.get(/databases/(default)/documents/documents/$(documentId)).data.clientId == request.auth.uid;
    }

    match /pdfs/{documentId}.pdf {
      allow delete: if ownsDocument(documentId);
    }

    match /pdfs/signed_{documentId}.pdf {
      allow delete: if ownsDocument(documentId);
    }

    // Match all files in the 'pdfs' folder
    match /pdfs/{allPaths=**} {
      // Allow anyone to read files. This is necessary for users to view documents via a shared link.
      allow read;

      // Allow write (create/update) operations only if:
      // 1. The user is authenticated (must be signed in via Firebase Auth).
      // 2. The uploaded file is a PDF.
      // 3. The file size is less than 5MB.
      allow write: if request.auth != null
                   && request.resource.contentType == 'application/pdf'
                   && request.resource.size < 5 * 1024 * 1024;
    }
  }
}
